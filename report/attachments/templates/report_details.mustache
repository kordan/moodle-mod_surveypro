{{!
    @template surveyproreport_attachments/report_details

    Paragraph of the detail page for attachment report.

    Example context (json):
    {
        "elementid": "user_45",
        "paragraphlabel": "User name",
        "paragraphcontent": "Foo Bar"
    }
}}
<div id="paragraph_{{{elementid}}}" class="fitem row">
    <div class="fitemtitle col-md-3">
        <span>{{{paragraphlabel}}}</span>
    </div>
    <div class="felement fstatic col-md-9">
        <div class="indent-0 label_static">
            {{{paragraphcontent}}}
        </div>
    </div>
</div>
